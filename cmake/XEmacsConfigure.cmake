    check_include_file("openssl/ssl.h" HAVE_OPENSSL_SSL_H)
    if(HAVE_OPENSSL_SSL_H)
      check_library_exists("ssl" "SSL_library_init" "" HAVE_LIBSSL)
      check_library_exists("crypto" "BIO_new" "" HAVE_LIBCRYPTO)
