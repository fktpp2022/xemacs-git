if(XEMACS_WITH_BIGNUM)
  find_package(GMP)
  if(GMP_FOUND)
    set(HAVE_GMP ON)
    set(HAVE_LIBGMP ON)
    include_directories(${GMP_INCLUDE_DIR})
  else()
    check_include_file("gmp.h" HAVE_GMP_H)
    if(HAVE_GMP_H)
      check_library_exists("gmp" "mpz_init" "" HAVE_LIBGMP2)
      if(HAVE_LIBGMP2)
        set(HAVE_GMP ON)
        set(HAVE_LIBGMP ON)
        set(GMP_LIBRARIES "gmp")
      endif()
    endif()
  endif()
  
  if(NOT HAVE_GMP)
    find_package(OpenSSL)
    if(OPENSSL_FOUND)
      set(HAVE_OPENSSL ON)
      set(HAVE_BIGNUM ON)
      include_directories(${OPENSSL_INCLUDE_DIR})
    endif()
  endif()
endif()

if(XEMACS_WITH_TLS)
