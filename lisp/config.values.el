;;; Commentary:

;; Extract all the @foo@ configuration symbols from ../configure to make them
;; available to elisp later (see config.el).
;; Primarily useful for creating ridiculously verbose bug reports, but also
;; helpful in moving C utility programs to Lisp.
;;
;; See lisp/config.el, ../configure.ac for more details.
;;
;; This script needs only to be run occasionally (before a Net release) by an
;; XEmacs Maintainer (consider yourself so blessed, if you are actually
;; reading this commentary).

(let ((configure (expand-file-name "configure" source-directory))
      subst define)
  (unless (file-readable-p configure)
    (error 'file-error "Cannot read file" configure))
  (with-temp-buffer
    (insert-file-contents configure)
    (goto-char (point-min))
    (if (not (search-forward "\nac_subst_vars='" nil t))
	(error 'syntax-error "Cannot find ac_subst_vars in file"
	       configure)
      (setq subst (split-string-by-char
		   (buffer-substring
		    (point)
		    (progn (skip-chars-forward "^'")
			   (point)))
		   ?\n)))
    (goto-char (point-min))
    (while (re-search-forward
	    "printf \"%s\\\\n\" \"#define \\([^ ]+\\) .*\" >>confdefs.h$"
	    nil t)
      (push (match-string 1) define)
      (when (and (> (length (car define)) 1) (eql (aref (car define) 0) ?$))
	;; Those #defines generated by examining what xmkmf(1) outputs
	;; have an AC_DEFINE_UNQUOTED() generated programmatically; we
	;; cannot work out what they are without access to the
	;; configure-time output, which is inappropriate for this
	;; file. Just remove them from config.values.in.
	(pop define)))
    (setq subst (delete-duplicates (sort subst #'string-lessp) :test #'equal)
	  define (sort
		  ;; We can't handle distinct values for AC_SUBST and AC_DEFINE (and it is , avoid duplicate entries
		  (set-difference (delete-duplicates define :test #'equal)
				  subst :test #'equal)
		  #'string-lessp))
    (erase-buffer)
    (kill-all-local-variables)
    (insert "\
;;; Do not edit this file!
;;; This file was automatically generated, by config.values.elc, from
;;; configure, which was itself automatically generated from configure.ac.
;;;
;;; See lisp/config.el for details on how this file is used.
;;;
;;; You are trapped in a twisty maze of strange-looking files, all autogenerated...

;;; configure        is created, from configure.ac,     by autoconf
;;; config.values.in is created, from configure,        by config.values.el
;;; config.values    is created, from config.values.in, by configure
;;; config.values    is read by lisp/config.el,
;;;                  to create the (Lisp object) config-value-hash-table

;;; Variables defined in configure by AC_SUBST follow:
;;; (These are used in Makefiles)

")
    (mapc #'(lambda (string)
	      (format-into (current-buffer) "%s \"@%s@\"\n"
			   string string))
	  subst)
    (insert "
;;; Variables defined in configure by AC_DEFINE and AC_DEFINE_UNQUOTED follow:
;;; (These are used in C code)

")
    (mapc #'(lambda (string)
	      (format-into (current-buffer) "%s \"@%s@\"\n"
			   string string))
	  define)
    (insert "
;;; config.values.in ends here\n")
    (write-file (expand-file-name "config.values.in" doc-directory))
    (kill-buffer (current-buffer))))

;;; config.values.el ends here
